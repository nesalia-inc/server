{
  "name": "@deessejs/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:run": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.17.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.0.0"
  }
}
