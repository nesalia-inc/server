{
  "name": "@deessejs/server",
  "version": "1.0.0",
  "type": "module",
  "description": "Modern functional-first RPC protocol for type-safe APIs",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:run": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@deessejs/fp": "*",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@deessejs/fp": "^3.0.0",
    "@eslint/js": "^9.17.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.0.0",
    "zod": "^3.0.0"
  }
}
